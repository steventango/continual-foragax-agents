{
    "agent": "DQN_reward_trace",
    "problem": "Foragax",
    "total_steps": 1000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": [0.05, 0.1, 0.25],
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxSquareWaveTwoBiome-v11",
            "aperture_size": 9,
            "observation_type": "color"
        },
        "experiment": {
            "seed_offset": 1000000
        },
        "gamma": 0.99,
        "use_reward_trace": true,
        "reward_trace_decay": [
            0.9,
            0.99
        ],
        "optimizer": {
            "name": "Adam",
            "alpha": [
                0.001,
                0.0003,
                0.0001
            ],
            "beta1": 0.9,
            "beta2": 0.999,
            "eps": 1e-5
        },
        "representation": {
            "type": "ForagerNet",
            "hidden": 64,
            "layers": 2,
            "conv": "None",
            "use_layernorm": true,
            "scalar_features": [
                "reward_trace"
            ]
        },
        "update_freq": 4
    }
}
