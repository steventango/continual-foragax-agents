{
    "agent": "DQN",
    "problem": "Foragax",
    "total_steps": 10000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.05,
        "use_past_action": true,
        "use_past_reward": true,
        "target_refresh": [
            1,
            128
        ],
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxSquareWaveTwoBiome-v11",
            "aperture_size": 9,
            "random_shift_max_steps": 10000000,
			"observation_type": "rgb"
        },
        "experiment": {
            "seed_offset": 0
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": [
                0.003,
                0.001,
                0.0003,
                0.0001,
                3e-05,
                1e-05
            ],
            "beta1": 0.9,
            "beta2": [
                0.9,
                0.999
            ],
            "eps": [
                0.01,
                1e-08
            ]
        },
        "representation": {
            "type": "Forager2LayerNormNet",
            "hidden": 64
        },
        "update_freq": 4
    }
}
