{
    "agent": "DRQN_RTU",
    "problem": "Foragax",
    "total_steps": 10000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.1,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxSquareWaveTwoBiome-v11",
            "aperture_size": 9,
            "observation_type": "color"
        },
        "experiment": {
            "seed_offset": 0
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": 0.001,
            "beta1": 0.9,
            "beta2": 0.999,
            "eps": 1e-05
        },
        "representation": {
            "type": "DRQNRTUNet",
            "hidden": 64,
            "rtu_hidden": 32,
            "rtu_params_type": "exp_exp",
            "rtu_activation": "relu",
            "pre_rtu_layers": 0,
            "post_rtu_layers": 1,
            "use_layernorm": true
        },
        "update_freq": 4,
        "sequence_length": 16,
        "burn_in_steps": 4
    }
}
