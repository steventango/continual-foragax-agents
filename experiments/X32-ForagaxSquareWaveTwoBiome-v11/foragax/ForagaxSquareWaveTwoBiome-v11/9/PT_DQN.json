{
    "agent": "PT_DQN",
    "problem": "Foragax",
    "total_steps": 10000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.25,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxSquareWaveTwoBiome-v11",
            "aperture_size": 9,
            "observation_type": "color"
        },
        "experiment": {
            "seed_offset": 0
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": 0.0003,
            "beta1": 0.9,
            "beta2": 0.999,
            "eps": 1e-05
        },
        "representation": {
            "type": "ForagerNet",
            "hidden": 32,
            "layers": 2,
            "conv": "None",
            "use_layernorm": true
        },
        "update_freq": 4,
        "pt_update_freq": 2500,
        "pt_decay": 0.95,
        "pm_buffer_size": 10000,
        "pt_optimizer": {
            "name": "SGD",
            "alpha_ratio": 0.0001
        }
    }
}