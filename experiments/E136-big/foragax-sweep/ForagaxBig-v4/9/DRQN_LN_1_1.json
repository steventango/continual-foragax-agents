{
    "agent": "DRQN_LN_1_1",
    "problem": "Foragax",
    "total_steps": 1000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.05,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 4,
        "environment": {
            "env_id": "ForagaxBig-v4",
            "aperture_size": 9,
            "observation_type": "rgb"
        },
        "experiment": {
            "seed_offset": 1000000
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": [
                0.001,
                0.0003,
                0.0001
            ],
            "beta1": 0.9,
            "beta2": [
                0.9,
                0.999
            ],
            "eps": 1e-5
        },
        "representation": {
            "type": "ForagerGRUNetReLU",
            "hidden": 64,
            "layers": 2,
            "use_layernorm": true,
            "pre_gru_layers": 1,
            "post_gru_layers": 1
        },
        "update_freq": 4,
        "sequence_length": 64,
        "burn_in_steps": 16
    }
}
