{
    "agent": "DQN_L2",
    "problem": "Foragax",
    "total_steps": 1000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.05,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxBig-v5",
            "aperture_size": 9,
            "observation_type": "rgb"
        },
        "experiment": {
            "seed_offset": 0,
            "video_length": 10000,
            "video_every": 100000
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": 3e-05,
            "beta1": 0.9,
            "beta2": 0.9,
            "eps": 1e-5
        },
        "representation": {
            "type": "Forager2Net",
            "hidden": 64
        },
        "update_freq": 4,
        "lambda_l2": 0.0001
    }
}
