{
    "agent": "DQN_LN_HINT_frozen_500K",
    "problem": "Foragax",
    "total_steps": 1000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.1,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxBig-v5",
            "aperture_size": 9,
            "observation_type": "rgb",
            "hint_duration": 100
        },
        "experiment": {
            "seed_offset": 0,
            "video_length": 10000,
            "video_every": 100000
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": 0.001,
            "beta1": 0.9,
            "beta2": 0.999,
            "eps": 1e-05
        },
        "representation": {
            "type": "ForagerNet",
            "hidden": 64,
            "layers": 2,
            "use_layernorm": true,
            "scalar_features": "hint,last_action,last_reward",
            "conv": "PConv2DConv2D"
        },
        "update_freq": 4,
        "freeze_steps": 500000
    }
}
