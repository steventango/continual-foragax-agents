{
    "agent": "DQN",
    "problem": "Foragax",
    "total_steps": 500000,
    "episode_cutoff": -1,
    "metaParameters": {
        "initial_epsilon": 1.0,
        "final_epsilon": 0.05,
        "epsilon_linear_decay": 400000,
        "target_refresh": 1,
        "buffer_size": 10000,
        "buffer_min_size": 32,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxTwoBiomeLarge-v1",
            "aperture_size": 7
        },
        "experiment": {
            "seed_offset": 0
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": 0.0001,
            "beta1": 0.9,
            "beta2": 0.999,
            "eps": 0.01
        },
        "representation": {
            "type": "Forager2Net",
            "hidden": 64
        },
        "update_freq": 1
    }
}
