{
    "agent": "DQN_reward_trace",
    "problem": "Foragax",
    "total_steps": 10000000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.05,
        "use_reward_trace": true,
        "reward_trace_decay": 0.99,
        "use_past_action": true,
        "use_past_reward": true,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxSquareWaveTwoBiome-v10",
            "aperture_size": 9,
            "random_shift_max_steps": 10000000
        },
        "experiment": {
            "seed_offset": 1000000
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": 0.001,
            "beta1": 0.9,
            "beta2": 0.999,
            "eps": 1e-08
        },
        "representation": {
            "type": "Forager2LayerNormNet",
            "hidden": 64
        },
        "update_freq": 4
    }
}