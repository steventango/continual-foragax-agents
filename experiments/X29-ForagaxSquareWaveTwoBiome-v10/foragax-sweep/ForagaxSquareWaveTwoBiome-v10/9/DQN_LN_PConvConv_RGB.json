{
    "agent": "DQN_LN_PConvConv_RGB",
    "problem": "Foragax",
    "total_steps": 100000,
    "episode_cutoff": -1,
    "metaParameters": {
        "epsilon": 0.05,
        "target_refresh": 128,
        "buffer_size": 1000,
        "buffer_min_size": 50,
        "batch": 32,
        "environment": {
            "env_id": "ForagaxSquareWaveTwoBiome-v10",
            "aperture_size": 9,
            "observation_type": "rgb"
        },
        "experiment": {
            "seed_offset": 1000000
        },
        "gamma": 0.99,
        "optimizer": {
            "name": "Adam",
            "alpha": [
                0.001,
                0.0003,
                0.0001
            ],
            "beta1": 0.9,
            "beta2": [
                0.9,
                0.999
            ],
            "eps": 1e-5
        },
        "representation": {
            "type": "ForagerNet",
            "hidden": 64,
            "layers": 2,
            "use_layernorm": true,
            "conv": "PConv2DConv2D"
        },
        "update_freq": 4
    }
}
